{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.12.0 <23",
        "npm": ">=10"
    },
    "scripts": {
        "build": "vite build",
        "predev": "node -e \"const p=process.versions.node.split('.').map(Number);const ok=(p[0]===20&&p[1]>=19)||(p[0]===22&&p[1]>=12);if(!ok){console.error('Vite 7 needs Node 20.19+ or 22.12+ (Node 21 is unsupported). You have '+process.version+'. Run: nvm use (see .nvmrc) or install Node 22 LTS.');process.exit(1)}\"",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@inertiajs/react": "^3.0.3",
        "@tinymce/tinymce-react": "^6.3.0",
        "@vitejs/plugin-react": "^4.7.0",
        "apexcharts": "^5.10.6",
        "chart.js": "^4.5.1",
        "lucide-react": "^1.8.0",
        "react": "^19.2.5",
        "react-apexcharts": "^2.1.0",
        "react-chartjs-2": "^5.3.1",
        "react-dom": "^19.2.5",
        "tinymce": "^8.5.0"
    }
}
